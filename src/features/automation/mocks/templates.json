[
  {
    "id": "tpl-new-lead",
    "name": "New Lead Automation",
    "description": "Qualify new leads using Gemini AI, branch by budget/value, and assign sales representatives automatically.",
    "status": "draft",
    "trigger": "Lead Created",
    "nodes": [
      {
        "id": "node-lead-created",
        "type": "Trigger",
        "name": "Lead Created",
        "position": { "x": 50, "y": 200 },
        "inputs": [],
        "outputs": ["Output"],
        "configuration": {
          "triggerType": "Lead Created"
        }
      },
      {
        "id": "node-ai-qualify",
        "type": "AI",
        "name": "AI Qualify Lead",
        "position": { "x": 300, "y": 200 },
        "inputs": ["Input"],
        "outputs": ["Output"],
        "configuration": {
          "aiPrompt": "Evaluate the lead details, domain size, and budget. Classify as High-Value or Standard.",
          "aiModel": "gemini-1.5-pro"
        }
      },
      {
        "id": "node-check-value",
        "type": "Condition",
        "name": "Is High Value?",
        "position": { "x": 550, "y": 200 },
        "inputs": ["Input"],
        "outputs": ["Yes", "No"],
        "configuration": {
          "conditionExpression": "lead.score > 80 || lead.budget > 10000"
        }
      },
      {
        "id": "node-assign-sales",
        "type": "Action",
        "name": "Assign Sales Executive",
        "position": { "x": 800, "y": 100 },
        "inputs": ["Input"],
        "outputs": ["Output"],
        "configuration": {
          "actionType": "Assign User",
          "assigneeId": "sales-lead-jack"
        }
      },
      {
        "id": "node-notify-admin",
        "type": "Notification",
        "name": "Notify Sales Channel",
        "position": { "x": 1050, "y": 100 },
        "inputs": ["Input"],
        "outputs": ["Output"],
        "configuration": {
          "actionType": "Notify User",
          "notificationMessage": "New High-Value Lead assignment: {{lead.name}}"
        }
      },
      {
        "id": "node-nurture-email",
        "type": "Action",
        "name": "Send Nurturing Email",
        "position": { "x": 800, "y": 320 },
        "inputs": ["Input"],
        "outputs": ["Output"],
        "configuration": {
          "actionType": "Send Email",
          "emailTemplate": "Standard Lead Welcome Series"
        }
      }
    ],
    "connections": [
      {
        "id": "conn-1",
        "sourceNodeId": "node-lead-created",
        "targetNodeId": "node-ai-qualify",
        "sourceOutputPort": "Output",
        "targetInputPort": "Input"
      },
      {
        "id": "conn-2",
        "sourceNodeId": "node-ai-qualify",
        "targetNodeId": "node-check-value",
        "sourceOutputPort": "Output",
        "targetInputPort": "Input"
      },
      {
        "id": "conn-3",
        "sourceNodeId": "node-check-value",
        "targetNodeId": "node-assign-sales",
        "sourceOutputPort": "Yes",
        "targetInputPort": "Input"
      },
      {
        "id": "conn-4",
        "sourceNodeId": "node-assign-sales",
        "targetNodeId": "node-notify-admin",
        "sourceOutputPort": "Output",
        "targetInputPort": "Input"
      },
      {
        "id": "conn-5",
        "sourceNodeId": "node-check-value",
        "targetNodeId": "node-nurture-email",
        "sourceOutputPort": "No",
        "targetInputPort": "Input"
      }
    ],
    "createdBy": "System Admin",
    "createdAt": "2026-07-01T12:00:00Z",
    "updatedAt": "2026-07-01T12:00:00Z"
  },
