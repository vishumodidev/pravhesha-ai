  {
    "id": "tpl-task-escalation",
    "name": "Task Escalation",
    "description": "Waits 24 hours after a task is due. If it is still pending, escalates the ownership and alerts a manager.",
    "status": "draft",
    "trigger": "Task Due",
    "nodes": [
      {
        "id": "node-esc-due",
        "type": "Trigger",
        "name": "Task Due Alert",
        "position": { "x": 50, "y": 200 },
        "inputs": [],
        "outputs": ["Output"],
        "configuration": {
          "triggerType": "Task Due"
        }
      },
      {
        "id": "node-esc-wait",
        "type": "Delay",
        "name": "Wait 24 Hours",
        "position": { "x": 300, "y": 200 },
        "inputs": ["Input"],
        "outputs": ["Output"],
        "configuration": {
          "delayDuration": 24,
          "delayUnit": "hours"
        }
      },
      {
        "id": "node-esc-check",
        "type": "Condition",
        "name": "Still Pending?",
        "position": { "x": 550, "y": 200 },
        "inputs": ["Input"],
        "outputs": ["Yes", "No"],
        "configuration": {
          "conditionExpression": "task.status !== 'Completed'"
        }
      },
      {
        "id": "node-esc-assign",
        "type": "Action",
        "name": "Escalate to Manager",
        "position": { "x": 800, "y": 100 },
        "inputs": ["Input"],
        "outputs": ["Output"],
        "configuration": {
          "actionType": "Assign User",
          "assigneeId": "manager-sarah"
        }
      },
      {
        "id": "node-esc-notify",
        "type": "Notification",
        "name": "Alert Manager",
        "position": { "x": 1050, "y": 100 },
        "inputs": ["Input"],
        "outputs": ["Output"],
        "configuration": {
          "actionType": "Notify User",
          "notificationMessage": "ALERT: Task Escalated. ID: {{task.id}} is overdue by 24h."
        }
      }
    ],
    "connections": [
      {
        "id": "conn-e1",
        "sourceNodeId": "node-esc-due",
        "targetNodeId": "node-esc-wait",
        "sourceOutputPort": "Output",
        "targetInputPort": "Input"
      },
      {
        "id": "conn-e2",
        "sourceNodeId": "node-esc-wait",
        "targetNodeId": "node-esc-check",
        "sourceOutputPort": "Output",
        "targetInputPort": "Input"
      },
      {
        "id": "conn-e3",
        "sourceNodeId": "node-esc-check",
        "targetNodeId": "node-esc-assign",
        "sourceOutputPort": "Yes",
        "targetInputPort": "Input"
      },
      {
        "id": "conn-e4",
        "sourceNodeId": "node-esc-assign",
        "targetNodeId": "node-esc-notify",
        "sourceOutputPort": "Output",
        "targetInputPort": "Input"
      }
    ],
    "createdBy": "Operations Lead",
    "createdAt": "2026-07-04T15:30:00Z",
    "updatedAt": "2026-07-04T15:30:00Z"
  },
